<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_dialog_project">

    <TextView
        android:id="@+id/tvDialogTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Create New Project"
        android:textColor="@color/smartmove_text_primary"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvDialogSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Start a new moving project. It will become your active project."
        android:textColor="@color/smartmove_text_secondary"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/etProjectName"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_input"
        android:hint="e.g. Apartment Move"
        android:inputType="textCapWords"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="@color/smartmove_text_primary"
        android:textColorHint="@color/smartmove_text_secondary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:gravity="end"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnCancelProject"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginEnd="10dp"
            android:backgroundTint="#E5E7EB"
            android:text="Cancel"
            android:textAllCaps="false"
            android:textColor="@color/smartmove_text_primary"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnCreateProject"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:background="@drawable/bg_login_button"
            android:text="Create"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>