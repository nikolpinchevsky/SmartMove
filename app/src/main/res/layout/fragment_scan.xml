<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_login_screen">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="90dp">

        <TextView
            android:id="@+id/tvScanTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Scan QR Code"
            android:textColor="@color/smartmove_text_primary"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvScanSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Scan a box to instantly view its details"
            android:textColor="@color/smartmove_text_secondary"
            android:textSize="15sp" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardScanner"
            android:layout_width="match_parent"
            android:layout_height="430dp"
            android:layout_marginTop="22dp"
            android:elevation="6dp"
            app:cardBackgroundColor="#132033"
            app:cardCornerRadius="26dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Camera Preview"
                    android:textColor="#D6E4FF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <FrameLayout
                    android:layout_width="210dp"
                    android:layout_height="210dp"
                    android:layout_marginTop="28dp"
                    android:background="@drawable/bg_scan_frame">

                    <ImageView
                        android:layout_width="110dp"
                        android:layout_height="110dp"
                        android:layout_gravity="center"
                        android:contentDescription="QR preview"
                        android:src="@drawable/qr_code" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Align the QR code inside the frame"
                    android:textColor="#D6E4FF"
                    android:textSize="15sp" />

                <Button
                    android:id="@+id/btnStartScan"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="26dp"
                    android:background="@drawable/bg_login_button"
                    android:text="Start Scanning"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardScannedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:elevation="3dp"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Scanned Box Details"
                    android:textColor="@color/smartmove_text_secondary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvEmptyState"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="No box scanned yet"
                    android:textColor="@color/smartmove_text_secondary"
                    android:textSize="15sp" />

                <LinearLayout
                    android:id="@+id/layoutBoxDetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tvBoxName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kitchen Essentials"
                        android:textColor="@color/smartmove_text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvBoxQr"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="QR: SM-123"
                        android:textColor="@color/smartmove_text_secondary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvBoxPriority"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Priority: Red"
                        android:textColor="@color/smartmove_text_primary"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tvBoxStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Status: Closed"
                        android:textColor="@color/smartmove_text_primary"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tvBoxRoom"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Room: Kitchen"
                        android:textColor="@color/smartmove_text_primary"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tvBoxFragile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Fragile: Yes"
                        android:textColor="@color/smartmove_text_primary"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tvBoxValuable"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Valuable: No"
                        android:textColor="@color/smartmove_text_primary"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tvBoxItemsLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Items:"
                        android:textColor="@color/smartmove_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvBoxItems"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="plates, cups, glasses"
                        android:textColor="@color/smartmove_text_secondary"
                        android:textSize="14sp" />

                    <Button
                        android:id="@+id/btnOpenFullDetails"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_login_button"
                        android:text="Open Full Details"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>